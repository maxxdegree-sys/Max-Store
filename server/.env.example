# Maxx backend environment. All values are optional - sensible defaults
# are used if this file is absent. Copy to ".env" to override.

# Server
PORT=4000
JWT_SECRET=change-me-to-a-long-random-string

# Site URL (used inside generated SEO schema markup)
SITE_URL=https://alrafiq.pk

# ----- AI (Blog & SEO module) -----
# Leave USE_REAL_AI=false to use the built-in sample (stub) output - no key needed.
# Set USE_REAL_AI=true AND add at least one provider key for live AI.
# Groq is used first (generous free tier - get a key at https://console.groq.com).
# Claude is the automatic fallback if the Groq call fails.
USE_REAL_AI=false
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-3-5-sonnet-latest

# ----- Firebase Cloud Messaging (server push) -----
# Paste the full service account JSON as a single line (Firebase Console → Project settings → Service accounts → Generate new private key).
# Also copy the same VITE_FIREBASE_* values into the project root .env for the frontend.
FIREBASE_SERVICE_ACCOUNT_JSON=
# Optional mirrors of client Firebase env (used by /firebase-config.js in production)
FIREBASE_VAPID_KEY=
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=
