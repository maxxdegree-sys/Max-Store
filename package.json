{
  "name": "maxx-shopping",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Premium eCommerce platform for Maxx, Kharian Pakistan",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext js,jsx --report-unused-disable-directives --max-warnings 0",
    "server": "node --env-file=server/.env server/src/index.js",
    "client": "vite",
    "dev:all": "concurrently -k -n SERVER,CLIENT -c magenta,cyan \"npm run server\" \"node scripts/wait-for-api.js && npm run client\"",
    "setup": "npm install",
    "start": "node --env-file-if-exists=server/.env server/src/index.js",
    "build:all": "npm install --prefix server && npm run build",
    "postinstall": "npm install --prefix server"
  },
  "dependencies": {
    "@reduxjs/toolkit": "^2.2.5",
    "firebase": "^10.12.2",
    "framer-motion": "^11.2.10",
    "lucide-react": "^0.400.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-helmet-async": "^2.0.5",
    "react-hot-toast": "^2.4.1",
    "react-redux": "^9.1.2",
    "react-router-dom": "^6.23.1",
    "recharts": "^2.12.7",
    "swiper": "^11.1.4"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.34.2",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-refresh": "^0.4.7",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "vite": "^5.3.1",
    "vite-plugin-pwa": "^0.20.0"
  }
}
